rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, ['admin', 'member'])
    //   - joinedAt: timestamp (optional)
    //
    // Collection: /groups/{groupId}
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - createdBy: string (required, userId)
    //   - createdAt: timestamp (required)
    //
    // Collection: /groups/{groupId}/contributions/{contributionId}
    // Fields:
    //   - userId: string (required)
    //   - groupId: string (required)
    //   - amount: number (required, positive)
    //   - type: string (required, ['savings', 'social_fund'])
    //   - date: timestamp (required)
    //   - status: string (required, ['pending', 'confirmed'])
    //
    // Collection: /groups/{groupId}/loans/{loanId}
    // Fields:
    //   - userId: string (required)
    //   - groupId: string (required)
    //   - amount: number (required, positive)
    //   - interestRate: number (required)
    //   - status: string (required, ['requested', 'approved', 'rejected', 'active', 'repaid'])
    //   - requestedAt: timestamp (required)
    //   - dueDate: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "samwelemmanuelezekiel@gmail.com";
    }

    function isValidEmail(email) {
      return email is string && (email == "" || email.matches(".*@.*\\..*"));
    }

    function isPositive(val) {
      return val is number && val > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow all authenticated users to read user profiles so group members can see each other
      // Each doc must pass the read rule for a query to succeed
      allow read: if isAuthenticated();
      
      // Strict write access
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /groups/{groupId} {
      function isValidGroup(data) {
        return data.keys().hasAll(['name', 'createdBy', 'createdAt', 'joinCode']) &&
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.joinCode is string && data.joinCode.size() >= 4 &&
               data.createdBy == request.auth.uid &&
               (!('phoneNumber' in data) || data.phoneNumber is string);
      }

      // Allow reading if member OR if querying by joinCode (for joining)
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && isValidGroup(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();

      match /contributions/{contributionId} {
        function isValidContribution(data) {
          return data.keys().hasAll(['userId', 'groupId', 'amount', 'type', 'date', 'status', 'paymentMethod']) &&
                 data.userId is string &&
                 data.groupId == groupId &&
                 isPositive(data.amount) &&
                 data.type in ['savings', 'social_fund'] &&
                 data.status in ['pending', 'confirmed'] &&
                 data.paymentMethod in ['mobile_money', 'bank_transfer', 'cash'] &&
                 (!('provider' in data) || data.provider is string) &&
                 (!('phoneNumber' in data) || data.phoneNumber is string);
        }

        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidContribution(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /loans/{loanId} {
        function isValidLoan(data) {
          return data.keys().hasAll(['userId', 'groupId', 'amount', 'interestRate', 'status', 'requestedAt']) &&
                 data.userId is string &&
                 data.groupId == groupId &&
                 isPositive(data.amount) &&
                 data.status in ['requested', 'approved', 'rejected', 'active', 'repaid'];
        }

        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidLoan(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'requested');
        allow delete: if isAdmin();
      }

      match /withdrawals/{withdrawalId} {
        function isValidWithdrawal(data) {
          return data.keys().hasAll(['userId', 'groupId', 'amount', 'status', 'requestedAt', 'otpCode']) &&
                 data.userId is string &&
                 data.groupId == groupId &&
                 isPositive(data.amount) &&
                 data.status in ['requested', 'pending_approval', 'approved', 'rejected', 'completed'];
        }

        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
        // Only admins can update status to approved/completed, or add approvals
        allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'requested');
        allow delete: if isAdmin();
      }
    }
  }
}
