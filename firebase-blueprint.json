{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message within a group",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "A member of the PamojaVault group",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Group": {
      "title": "Group",
      "description": "A PamojaVault group",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "joinCode": { "type": "string", "description": "Code used by others to join the group" },
        "adminCount": { "type": "number", "description": "Number of admins required for approvals" },
        "phoneNumber": { "type": "string", "description": "Group contact phone number for administrative alerts" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy", "joinCode"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "A savings contribution by a member",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["savings", "social_fund"] },
        "paymentMethod": { "type": "string", "enum": ["mobile_money", "bank_transfer", "cash"] },
        "provider": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed"] }
      },
      "required": ["userId", "groupId", "amount", "type", "date"]
    },
    "Loan": {
      "title": "Loan",
      "description": "A loan request or active loan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "interestRate": { "type": "number" },
        "status": { "type": "string", "enum": ["requested", "approved", "rejected", "active", "repaid"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "groupId", "amount", "status"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request requiring multi-admin OTP approval",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "pending_approval", "approved", "rejected", "completed"] },
        "otpCode": { "type": "string", "description": "The secret OTP required for this transaction" },
        "approvals": { "type": "object", "description": "Map of adminUid to approval status" },
        "requestedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "groupId", "amount", "status", "otpCode"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/groups/{groupId}": { "schema": "Group", "description": "PamojaVault groups" },
    "/groups/{groupId}/contributions/{contributionId}": { "schema": "Contribution", "description": "Group contributions" },
    "/groups/{groupId}/loans/{loanId}": { "schema": "Loan", "description": "Group loans" },
    "/groups/{groupId}/withdrawals/{withdrawalId}": { "schema": "Withdrawal", "description": "Group withdrawals" },
    "/groups/{groupId}/messages/{messageId}": { "schema": "Message", "description": "Group chat messages" }
  }
}
