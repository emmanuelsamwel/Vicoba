{
  "entities": {
    "User": {
      "title": "User",
      "description": "A member of the VICOBA group",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Group": {
      "title": "Group",
      "description": "A VICOBA group",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "A savings contribution by a member",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["savings", "social_fund"] },
        "phoneNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed"] }
      },
      "required": ["userId", "groupId", "amount", "type", "date"]
    },
    "Loan": {
      "title": "Loan",
      "description": "A loan request or active loan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "interestRate": { "type": "number" },
        "status": { "type": "string", "enum": ["requested", "approved", "rejected", "active", "repaid"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "groupId", "amount", "status"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request from the social fund or savings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "approved", "rejected", "completed"] },
        "requestedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "groupId", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/groups/{groupId}": { "schema": "Group", "description": "VICOBA groups" },
    "/groups/{groupId}/contributions/{contributionId}": { "schema": "Contribution", "description": "Group contributions" },
    "/groups/{groupId}/loans/{loanId}": { "schema": "Loan", "description": "Group loans" },
    "/groups/{groupId}/withdrawals/{withdrawalId}": { "schema": "Withdrawal", "description": "Group withdrawals" }
  }
}
